# MiniMax API Key (https://platform.minimaxi.com/user-center/basic-information/interface-key)
MINIMAX_API_KEY=your_minimax_api_key

# Requesty API Key (optional, for gpt-image-1 / gemini comparison)
REQUESTY_API_KEY=rqsty-sk-xxxxxxxxxxxxxxxx

# OpenRouter API Key (optional, for gpt-image-2)
OPENROUTER_API_KEY=your_openrouter_api_key

# PackyAPI Token (optional, for gpt-image-2)
PACKYAPI_TOKEN=your_packyapi_token

# Optional: override API base URLs
# MINIMAX_BASE_URL=https://api.minimaxi.com
# REQUESTY_BASE_URL=https://router.requesty.ai/v1
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# PACKYAPI_BASE_URL=https://www.packyapi.com/v1

# Active model registry key (image-01 | gpt-image-1 | gpt-image-2-packyapi)
ACTIVE_MODEL=image-01

# Feature toggle: 模型选择 UI
# true  → 前端显示下拉菜单，用户可选模型
# false → 前端隐藏模型选择区，统一用 ACTIVE_MODEL；业务流程不出现任何模型信息
SHOW_MODEL_SELECT=true
